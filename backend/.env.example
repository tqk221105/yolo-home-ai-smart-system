ADAFRUIT_USERNAME=your_adafruit_username
ADAFRUIT_API_KEY=aio_xxxxxxxxxxxxxxxxxxxx
ADAFRUIT_DASHBOARD_KEY=your_dashboard_key
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# Model đèn: «Light» (lux) + tùy chọn «Hour» (giờ trong ngày, 0–24) nếu CSV có cột thời gian.
# LIGHT_USE_TIME_FEATURE=0  -> không thêm Hour (chỉ lux).
# Cột thời gian: ưu tiên LIGHT_DATETIME_COL (vd date,timestamp); không set thì tự tìm date|timestamp|...
# LIGHT_DATETIME_DAYFIRST=0 -> parse kiểu US (mm/dd); mặc định 1 cho dd/mm.
# Khi infer có Hour: giờ máy chủ; LIGHT_INFER_UTC=1 -> UTC.
# ── Dataset đèn (train.py / retrain.py nhánh base) ──
# Rỗng = backend/data/light_dataset.csv
# Tương đối so với thư mục backend: data/my_light.csv
# Hoặc đường dẫn tuyệt đối: D:/datasets/home_light.csv
# LIGHT_DATA_PATH=data/light_dataset.csv

# ── Nhãn Occupancy trong CSV ──
# Mặc định OFF: học nhãn «cần bật đèn» từ lux (Lux < ngưỡng → 1).
LIGHT_NEED_ON_MAX_LUX=380
# Dataset của bạn đã có Occupancy đúng nghĩa (ví dụ nhãn từ bộ dataset mới) → bật:
# LIGHT_USE_ORIGINAL_OCCUPANCY_LABELS=1

# Relay/UI đảo polarity với OUT trong API
# LIGHT_INVERT_OUTPUT=1

# FaceAI
# Empty/default = backend/data/faces/<label>/*.jpg|png|webp
FACE_DATA_DIR=data/faces
# Empty/default = backend/models/face_model.pkl
FACE_MODEL_PATH=models/face_model.pkl
FACE_CONFIDENCE_THRESHOLD=0.90
FACE_MIN_SAMPLES_PER_LABEL=3
FACE_DISTANCE_MARGIN=0.12
FACE_REQUIRE_DETECTED_FACE=1
FACE_MIN_AREA_RATIO=0.08
FACE_CENTER_TOLERANCE=0.28
ADAFRUIT_DOOR_FEED=lock-status
ADAFRUIT_DOOR_OPEN_VALUE=UNLOCKED
FACE_MAX_IMAGE_BYTES=5242880
